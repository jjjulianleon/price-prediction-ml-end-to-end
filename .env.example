# Plantilla base para la fase Snowflake-first del proyecto final.
# Copia este archivo a `.env` y completa los valores reales.
# No subas el archivo `.env` a Git.

SNOWFLAKE_ACCOUNT=abc12345.us-east-1
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_secret_password
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=DM_FINAL_PROJECT
SNOWFLAKE_SCHEMA_RAW=RAW
SNOWFLAKE_SCHEMA_ANALYTICS=ANALYTICS
SNOWFLAKE_SCHEMA_ML=ML

# Rango de fechas para la fase base.
# Por ahora se configura un solo mes, pero la estructura ya soporta ampliar el rango.
DATA_START_DATE=2025-01-01
DATA_END_DATE=2025-01-31
TRAIN_END_DATE=2025-01-21
VAL_END_DATE=2025-01-27

# Etiqueta opcional del mes si el equipo la quiere para notebooks o trazabilidad.
NYC_TAXI_MONTH=2025-01
NYC_TLC_BASE_URL=https://d37ci6vzurychx.cloudfront.net/trip-data

# Carpeta local donde se guardan artefactos del modelo.
MODEL_DIR=data/models
