# Plantilla base para la fase Snowflake-first del proyecto final.
# Copia este archivo a `.env` y completa los valores reales.
# No subas el archivo `.env` a Git.

SNOWFLAKE_ACCOUNT=abc12345.us-east-1
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_secret_password
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=DM_FINAL_PROJECT
TRIP_TYPE=yellow
SNOWFLAKE_SCHEMA_RAW=RAW
SNOWFLAKE_SCHEMA_STAGING=STAGING
SNOWFLAKE_SCHEMA_ANALYTICS=ANALYTICS
SNOWFLAKE_SCHEMA_ML=ML

# `TRIP_TYPE` acepta `yellow`, `green` o `yellow,green`.
# Yellow y green se cargan en esquemas RAW separados y luego se integran en STAGING/ANALYTICS/ML.

# Directorios y switches operativos
LOCAL_DATA_DIR=data/raw
ENABLE_DOWNLOAD=true
ENABLE_STAGE_UPLOAD=true
ENABLE_COPY_INTO=true
ENABLE_ZONE_LOOKUP=false
ZONE_LOOKUP_PATH=data/raw/taxi_zone_lookup.csv

# Rango base recomendado: 6 meses.
# Split temporal mensual por defecto:
# train = enero-abril, validation = mayo, test = junio
DATA_START_DATE=2025-01-01
DATA_END_DATE=2025-06-30
TRAIN_END_DATE=2025-04-30
VAL_END_DATE=2025-05-31

# Etiqueta opcional de la ventana para notebooks o trazabilidad.
NYC_TAXI_MONTH=2025-H1
NYC_TLC_BASE_URL=https://d37ci6vzurychx.cloudfront.net/trip-data

# Carpeta local donde se guardan artefactos del modelo.
# La ruta productiva espera `MODEL_DIR/nyc_taxi_fare_production.joblib`.
MODEL_DIR=data/models
MODEL_TARGET=fare_amount

# Parametros operativos de muestra y entrenamiento.
EDA_SAMPLE_LIMIT=10000
EDA_SAMPLE_SEED=42
TRAIN_SAMPLE_LIMIT=50000
TRAIN_SAMPLE_PCT=1.0
BATCH_SIZE=50000
TRAINING_BATCH_GRAIN=month
